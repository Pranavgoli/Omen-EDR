# Omen-EDR Hardened Gitignore
# OWASP A01:2025 Compliance - Zero Environment Leakage

# --- Python Environment ---
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Frontend / Node.js ---
node_modules/
frontend/node_modules/
.npm
dist/
dist-ssr/
*.local
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env.local

# --- Forensic Data & Logs (Sanitization) ---
# Prevents accidental upload of analyzer telemetry
*.evtx
*.evt
*.etl
*.pcap
*.pcapng
*.log
*.txt
*.csv
*.xml
*.json
*.gz
*.tar.gz
*.bak
*.config
*.out
*.gr

# EXCEPTIONS: Allow project configuration files
!package.json
!tsconfig.json
!package-lock.json

# --- Databases ---
# Prevents leaking incident history or security metadata
*.db
*.sqlite
*.sqlite3
omen_edr.db

# --- IDEs & OS Noise ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini
.gemini/

# --- Tools ---
build_standalone.py
*.exe
*.msi
